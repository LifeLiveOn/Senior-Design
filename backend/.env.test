# === OAuth ===
GOOGLE_CLIENT_ID=test-google-client-id.apps.googleusercontent.com

# === Django Core ===
SECRET_KEY=test-secret-key
DEBUG=1

# === Hosts & Domains ===
ALLOWED_HOSTS=localhost,127.0.0.1
